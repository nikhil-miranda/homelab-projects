# ==================== MEDIASTACK ====================
TZ=Asia/Kolkata
PUID=0
PGID=0
LAN_SUBNET=192.168.0.0/24
# Paths inside LXC (bind-mounted from Kingston SSD + /srv/config on NVMe)
# Config path is hardcoded to /mnt/config in docker-compose.yml
DATA_PATH=/mnt/kingston

# Render group GID — must match host (verify: getent group render)
RENDER_GID=993

# === VPN (gluetun) ===
VPN_SERVICE_PROVIDER=protonvpn
VPN_TYPE=wireguard
WIREGUARD_PRIVATE_KEY=REPLACE_ME
WIREGUARD_ADDRESSES=REPLACE_ME
WIREGUARD_PRESHARED_KEY=  # ProtonVPN does not use preshared keys — leave blank
SERVER_COUNTRIES=Netherlands

# === Tailscale ===
# Reusable auth key from https://login.tailscale.com/admin/settings/keys
TAILSCALE_AUTHKEY=REPLACE_ME
# Tailnet hostname for this node (shows in Tailscale admin and MagicDNS)
TS_HOSTNAME=jellyfin
