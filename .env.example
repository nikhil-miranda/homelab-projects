# ==================== SHARED ====================
TZ=Asia/Kolkata
PUID=0
PGID=0
LAN_SUBNET=192.168.0.0/24

# ==================== VESPER ====================
# Paths inside LXC (bind-mounted from /srv/ on aegis pve-root — no ZFS pool yet)
CONFIG_PATH=/mnt/config
MEDIA_PATH=/mnt/media
DOWNLOADS_PATH=/mnt/downloads

# Render group GID — must match host (verify: getent group render)
RENDER_GID=993

# === VPN (gluetun) ===
VPN_SERVICE_PROVIDER=protonvpn
VPN_TYPE=wireguard
WIREGUARD_PRIVATE_KEY=REPLACE_ME
WIREGUARD_ADDRESSES=REPLACE_ME
WIREGUARD_PRESHARED_KEY=  # ProtonVPN does not use preshared keys — leave blank
SERVER_COUNTRIES=Netherlands
